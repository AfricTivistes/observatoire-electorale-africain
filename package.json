{
      "name": "elections-africa",
      "version": "0.1.0",
      "private": true,
      "type": "module",
      "packageManager": "pnpm@10.26.1",
      "scripts": {
            "preinstall": "node -e \"if(process.env.npm_execpath?.indexOf('pnpm')===-1)throw new Error('Use pnpm: npm run install will NOT work, use pnpm install instead')\"",
            "dev": "astro dev",
            "start": "astro dev",
            "build": "astro build && npm run postbuild",
            "postbuild": "pagefind --site dist",
            "preview": "astro preview",
            "typecheck": "NODE_OPTIONS='--max-old-space-size=4096' astro check",
            "postinstall": "node patches/apply-patches.mjs"
      },
      "pnpm": {
            "onlyBuiltDependencies": [
                  "sharp",
                  "esbuild"
            ]
      },
      "dependencies": {
            "@astrojs/check": "0.9.9",
            "@astrojs/react": "^5.0.5",
            "@astrojs/tailwind": "^6.0.2",
            "@types/react": "^18.3.12",
            "@types/react-dom": "^18.3.1",
            "@types/react-simple-maps": "^3.0.6",
            "astro": "^6.3.5",
            "astro-heroicons": "^2.1.5-1",
            "astro-icon": "^1.1.2",
            "astro-nocodb": "^0.1.1",
            "axios": "^1.13.5",
            "chart.js": "^4.4.6",
            "d3-geo": "^3.1.1",
            "dotenv": "^16.4.7",
            "react": "^18.3.1",
            "react-chartjs-2": "^5.2.0",
            "react-dom": "^18.3.1",
            "react-icons": "^5.6.0",
            "react-simple-maps": "^3.0.0",
            "sharp": "0.34.5",
            "tailwindcss": "^3.4.15"
      },
      "devDependencies": {
            "astro-pagefind": "^1.8.3",
            "pagefind": "^1.3.0",
            "typescript": "^5.8.2"
      }
}
